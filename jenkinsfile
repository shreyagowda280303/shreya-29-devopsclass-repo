pipeline {
    agent any

    stages {
        stage ("1. clone the repo") {
            steps {
                echo "cloning the github repo"
                sh "git clone git@github.com:devopsccnaacademy/feb-weekend-weekday-devsecops-repo.git"
            }
        }

        stage ("2. update the system") {
            steps {
                echo "updating the system"
                sh "yum update -y"
                sh "yum upgrade -y"
                sh "dnf upgrade -y"
                sh "dnf update -y"
            }
        }

        stage ("3. install the required packages") {
            steps {
                echo "install the importanat packages"
                sh "yum install -y git"
                sh "yum install -y docker"
                sh "systemctl restart docker"
                sh "systemctl enable docker"
                sh "docker -v"
                sh "git -v"
            }
        }

        stage ("4. get the system commands output") {
            steps {
                echo "output of the linux commands"
                sh "iostat"
                sh "free -m"
                sh "df -h"
                sh "cal 2026"
                sh "date"
            }
        }
    }
}